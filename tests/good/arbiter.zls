(* The example of a cyclic token ring arbiter from Robert de Simone *)
(*- this is an example originaly written in Esterel that is described
 *- in the Esterel primer V5, by Gerard Berry 
 *- This example is used to illustrate the "constructive semantics" 
 *- of Esterel when interpreting an Esterel program as a circuit and 
 *- using a three-value logic for boolean operations (or, &&) 
 *- This example is written in a data-flow form in the paper:
 *- "The semantics and execution of a synchronous block-diagram language",
 *- by Stephen Edwards and Edward Lee, SCP, 2003
 *- it is used to illustrate the fix-point semantics given in their paper *)

(* The program, written here in the syntax of Zelus, is the direct
 *- transcription of the Edwards and Lee's version.
 *- Note that, in the ZRun interpreter, all imported functions are strict,
 *- that is, if f is an imported combinational function, f(e1,...,en)
 *- evaluates to bottom as soon as one of the ei evaluates to bottom.
 *- in particular if f is a boolean function (e.g., not, or, &&). *)
 
(* By default, the semantics for the mux [if/then/else] is lazy, i.e.,
 *- it is strict w.r.t the condition only, that is:
 *- if_lazy(bot, _, _) = bot
 *- if_lazy(true, x, _) = x
 *- if_lazy(false, _, y) = y *)

(* The arbiter.zls is not causal. It would be causal if boolean
 *- operation were interpreted in three-valued logic:
 *- true or _ = _ or true = true
 *- false && _ = _ && false = false
 *- x && y = x && y = if x then y else false
 *- x or y = y or x = if x then true else y
*)

(* To achieve that, replace [or] and [&&] by user-defined versions such that
 *- or(x, y) = if x then true else y
 *- &&(x, y) = if x then y else false
 *-
 *- and take the -esterel option such that the semantics of the mux is:
 *-
 *- if _ then x else x = x
 *- if x then y else z = if_lazy(x, y, z)
*)

(* Surprisingly, this example is causal using the simple lazy mux, that is,
 *- a simple sequential version of the or and of the && ! This is because
 *- [token_in] is the output of a unit delay, hence looking at its output
 *- first is enough. That is:

 *- o = sequential_or_gate (token_in, pass_in) first reads the value
 *- of token_in. If this equation is replaced by:
 *- o = sequential_or_gate (pass_in, token_in), that is, first read the
 *- value of pass_in, then there is a causality loop (o = bottom).
 *- Surprising isn't-it?
 *- This example of an bus arbiter was (at least, to me) a prototypical
 *- example of a valid synchronous circuit that needs the expressiveness
 *- of constructive causality. In fact, no; a lazy semantics is enough.
 *- yet, the writting with symetric operators (or, and) is far more
 *- elegant. If we want to model multi-emission, then we need the
 *- constructive definitions for or and and.
*)


let node sequential_and_gate(x,y) returns (z)
    if x then z = y else z = false

let node sequential_or_gate(x,y) returns (z)
    if x then z = true else z = y

let node sequential_or_gate(x, y) = if x then true else y
  
(* the two below are strict w.r.t their argument *)
let node and_gate(x,y) returns (z)
    z = x && y

let node or_gate(x,y) returns (z)
    z = x or y

(* the two below are implemented using the conditional. *)
(*
let node or_gate(x,y) = if x then y else false
let node and_gate(x, y) = if x then true else y
 *)
    
(* i is the initial value of one block *)
let node arbiter(i, request, pass_in, token_in)
  returns (grant, pass_out, token_out)
  local o
  do
    grant =  and_gate(request, o)
  and
    pass_out = and_gate(not request, o)
  and
   (* grant is given when there is a request and either 
   1/ it is my round or *)
   (* my left neibour had the token but did not take it *)
      o = sequential_or_gate (token_in, pass_in) (* (pass_in, token_in) *)
  and
    token_out = i fby token_in
  done
      
let node arbiter_three(request1, request2, request3)
    returns (grant1, grant2, grant3)
  local pass_out1,
        pass_out2,
        pass_out3,
        token_out1,
        token_out2,
        token_out3
  do
    grant1, pass_out1, token_out1 =
       arbiter(true, request1, pass_out3, token_out3)
  and
    grant2, pass_out2, token_out2 =
       arbiter(false, request2, pass_out1, token_out1)
  and
    grant3, pass_out3, token_out3 =
       arbiter(false, request3, pass_out2, token_out2)
  done

let node main1() returns (grant1, grant2, grant3) 
  local request1, request2, request3
  do
    request1 = true
  and
    request2 = true
  and
    request3 = true
  and
    grant1, grant2, grant3 =  arbiter_three(request1, request2, request3)
  done

(* the property that the arbiter must verify *)
(* No matter is the values for the three inputs *)
(* [request1, request2, request3] *)
(* at most one of the three output [grant1, grant2, grant3] can be true *)
(* at the same time *)
let safe (request1, request2, request3,
          grant1, grant2, grant3) returns (ok)
  ok = match grant1, grant2, grant3 with
       | (true, true, _) -> false
       | (false, true, true) -> false
       | _ -> true

let node main() returns (request1, request2, request3)
  local grant1, grant2, grant3
  do
    request1 = random_bool()
  and
    request2 = random_bool()
  and
    request3 = random_bool()
  and
    grant1, grant2, grant3 =  arbiter_three(request1, request2, request3)
  and
    assert safe(request1, request2, request3,
                grant1, grant2, grant3)
  done
  

