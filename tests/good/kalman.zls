let transpose<<n,m>>(x:[n][m]_) returns (o:[m][n]_)
  forward<<m>> [j] returns (oj out o)
    do forward<<n>> [i] returns (oji out oj)
           do oji = x.(i).(j) done
    done


let test_transpose_empty =
  assert (
    transpose<<0,2>>([||])
    = [| [||]; [||] |]
  )


let zeros_vec<<n>>() returns (o: [n]_)
  forward<<n>> returns (oi out o)
    do oi = 0.0 done

let zeros_mat<<n, m>>() returns (o: [n][m]_)
  forward<<n>> returns (oi out o)
    do oi = zeros_vec<<m>>() done

let eye<<n>>() returns (o: [n][n]_)
  forward<<n>>[i] returns (oi out o)
    do forward<<n>>[j] returns (oij out oi)
      do oij = if i = j then 1.0 else 0.0 done done

let add_vec<<n>>(x: [n]_, y: [n]_) returns (o: [n]_)
  forward (xi in x, yi in y) returns (oi out o)
    do oi = xi +. yi done

let sub_vec<<n>>(x: [n]_, y: [n]_) returns (o: [n]_)
  forward (xi in x, yi in y) returns (oi out o)
    do oi = xi -. yi done

let mul_ew_vec<<n>>(x: [n]_, y: [n]_) returns (o: [n]_)
  forward (xi in x, yi in y) returns (oi out o)
    do oi = xi *. yi done

let add_mat<<n,m>>(x: [n][m]_, y: [n][m]_) returns (o: [n][m]_)
  forward (xi in x, yi in y) returns (oi out o)
    do forward (xij in xi, yij in yi) returns (oij out oi)
      do oij = xij +. yij done
    done

let sub_mat<<n,m>>(x: [n][m]_, y: [n][m]_) returns (o: [n][m]_)
  forward (xi in x, yi in y) returns (oi out o)
    do forward (xij in xi, yij in yi) returns (oij out oi)
      do oij = xij -. yij done
    done

let dot_product<<n>>(x: [n]_, y: [n]_) returns (o: _)
  forward (xi in x, yi in y) returns (o init 0.0)
    do o = last o +. xi *. yi done

let mul_mat_vec<<n, m>>(l: [n][m]_, r: [m]_) returns (o: [n]_)
  forward<<n>>[i] (li in l) returns (oi out o)
    do oi = dot_product<<m>>(li, r) done

let mul_mat_mat<<n, m, p>>(l: [n][m]_, r: [m][p]_) returns (o: [n][p]_)
  local oT do
    forward<<p>>[j] (rTj in r.T) returns (oTj out oT)
      do oTj = mul_mat_vec<<n, m>>(l, rTj) done
    and
    o = oT.T
  done

let mul_mat_diag<<n, m>>(l: [n][m]_, d: [m]_) returns (o: [n][m]_)
  forward<<n>>[i] (li in l) returns (oi out o)
    do oi = mul_ew_vec<<m>>(li, d) done

let decompose_LDLt<<n>>(m: [n][n]int) returns (l: [n][n]_, d: [n]_)
  local lT
  do forward<<n>>[j] (mTj in m.T) returns (lTj out lT as lT_, dj out d as d_)
    local mTjLj, mTjj, mTjRj, lTjLj, lTjj, lTjRj, l_, lLjLj, ljLj, lRjLj
    do  mTjLj = mTj.(.. (j-1))
    and mTjj = mTj.(j)
    and mTjRj = mTj.((j+1) ..)
    and lTj = lTjLj ++ [| lTjj |] ++ lTjRj
    and l_ = transpose<<j, n>>(last lT_)
    and lLjLj = l_.(.. (j-1))
    and ljLj = l_.(j)
    and lRjLj = l_.((j+1) ..)

    and forward(j)[k] (ljk in ljLj, dk in last d_) returns (dj init mTjj)
      do dj = last dj -. (ljk *. ljk *. dk) done

    and forward(j)[i] returns (lij out lTjLj)
      do lij = 0.0 done

    and lTjj = 1.0
    and forward(n-j-1)[ji] (liLj in lRjLj, mij in mTjRj) returns (lij out lTjRj)
      local lij_dj
      do forward(j)[k] (ljk in ljLj, lik in liLj, dk in last d_)
           returns (lij_dj init mij)
          do lij_dj = last lij_dj -. lik *. ljk *. dk done
      and lij = lij_dj /. dj done
    done
  and
    l = lT.T
  done

let inverse_L<<n>>(l: [n][n]int) returns (lI: [n][n]int)
  forward<<n>>[i] (li in l) returns (lIi out lI as lI_)
    local lIiLi, lIii, lIiRi
    do forward(i)[j] (lI_Tj in (transpose<<i, n>>(last lI_)).(.. (i-1)), lij in li.(.. (i-1))) returns (lIij out lIiLi)
      do forward(i-j-1)[k] (lIkj in lI_Tj.((j+1) ..), lik in li.((j+1) .. (i-1))) returns (lIij init (-. lij))
        do lIij = last lIij -. lik *. lIkj done
      done
    and lIii = 1.0
    and forward(n-i-1)[j] returns (lIij out lIiRi)
      do lIij = 0.0 done
    and lIi = lIiLi ++ [| lIii |] ++ lIiRi
    done


let inverse_D<<n>>(d: [n]_) returns (o: [n]_)
  forward<<n>>[i] (di in d) returns (oi out o)
    do oi = 1.0 /. di done

let inverse_LDLt<<n>>(l: [n][n]_, d: [n]_) =
  let lI = inverse_L<<n>>(l) in
  let dI = inverse_D<<n>>(d) in
  let lIT_dI = mul_mat_diag<<n, n>>(lI.T, dI) in
  let o = mul_mat_mat<<n, n, n>>(lIT_dI, lI) in
  (o: [n][n]_)


let test_inverse_L_3x3 () =
  assert (
    inverse_L<<3>>([|[|1.0;0.0;0.0|]; [|3.0;1.0;0.0|]; [|60.0;2.0;1.0|]|])
    = [|[|1.0;0.0;0.0|]; [|-3.0;1.0;0.0|]; [|-54.0;-2.0;1.0|]|]
  )

let test_decompose_LDLt_3x3 () =
  let l, d = decompose_LDLt<<3>>([|[|2.0;6.0;120.0|];
                                   [|6.0;22.0;368.0|];
			           [|120.0;368.0;7224.0|]|]) in
  let expected_l = [|[|1.0;0.0;0.0|]; [|3.0;1.0;0.0|]; [|60.0;2.0;1.0|]|] in
  let expected_d = [|2.0;4.0;8.0|] in
  assert (l = expected_l && d = expected_d)

let test_inverse_D_3 () =
  assert (
    inverse_D<<3>>([|2.0;4.0;8.0|])
    = [|0.5;0.25;0.125|]
  )

let test_mul_mat_diag_3x3 () =
  assert (
    mul_mat_diag<<3, 3>>([|[|1.0;0.0;0.0|]; [|3.0;1.0;0.0|];
                         [|60.0;2.0;1.0|]|], [|2.0;4.0;8.0|])
    = [|[|2.0;0.0;0.0|];[|6.0;4.0;0.0|];[|120.0;8.0;8.0|]|]
  )

let test_inverse_LDLt_3x3 () =
  assert (
    inverse_LDLt<<3>>([|[|1.0;0.0;0.0|]; [|3.0;1.0;0.0|];
                      [|60.0;2.0;1.0|]|], [|2.0;4.0;8.0|])
    = [|[|367.25;12.75;-6.75|]; [|12.75;0.75;-0.25|]; [|-6.75;-0.25;0.125|]|]
  )

