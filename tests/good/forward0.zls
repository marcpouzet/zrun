
let node make1(n)() = 
  forward(n)(i in 0 to n-1) returns ([|oi|]) do oi = i done

let node make11(n)() returns (o) 
  forward(n)(i in 0 to n-1) returns (oi out o) do oi = i done

let node make2(n)() = 
  foreach(n)(i in 0 to n-1) returns ([|oi|]) do oi = i done

let node make22(n)() returns (o)  
  foreach(n)(i in 0 to n-1) returns (oi out o) do oi = i done

let node main1() returns ()
  assert (run (make1 4)() = run (make2 4) ())

let node main11() returns ()
  assert (run (make1 4)() = run (make11 4) ())

let node main22() returns ()
  assert (run (make2 4)() = run (make22 4) ())

let node f x = x.(4 .. 5)

let node main0 () =
  let t = run (make1(10))() in
  let v = f t in
  assert (v = [| 4; 5 |])

let f () =
  forward(10)[i] returns (o init 0)
    do o = 0 -> pre o + i done

let node main1 () returns (v)
  do v = f () and assert (v = 45) done

