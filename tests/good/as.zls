(* o_0 = 1 /\ oi = Sigma_{k = 0}^{i-1} o_k *)

let main1() returns (o)
  o = forward<<4>>[i]() returns ([|oi|] as o_)
    (* in iteration i, [o_ = o.(0 .. i-2)] *)
    (* that is, when [i = 0], [o_ = [||]] *)
    do
      oi = forward(i)[k] returns (ok init 0)
             do ok = last ok + o_.(k) done
    done

let zero<<n>>() returns (o)
  forward<<n>>() returns (oi out o)
    do oi = 0.0 done

let main2() returns (o)
  forward<<4>>[i]() returns (oi init 0)
    do
      oi = forward(i)[k] returns (ok init 0)
             do ok = last ok + (last o).(k) done
    done