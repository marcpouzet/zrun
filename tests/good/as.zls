let node main1() =
  forward<<4>>() returns ([|o1|] as o2)
    do o1 = forward(xi in last o2) returns (o init 0) do o = last o + xi done
    done

let node main0(o1) returns (o3)
  forward<<4>>(o in o1) returns (o2 init 0 out o3, o2 init 1 out o3)
    do o = 1 done

